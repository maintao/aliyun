{
  "name": "@fnmain/aliyun",
  "version": "4.0.1",
  "description": "aliyun utils",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "oss": [
        "dist/oss.d.ts"
      ],
      "ecs": [
        "dist/ecs.d.ts"
      ],
      "vi": [
        "dist/vi.d.ts"
      ],
      "oss-direct-upload": [
        "dist/oss-direct-upload/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./oss": {
      "types": "./dist/oss.d.ts",
      "default": "./dist/oss.js"
    },
    "./ecs": {
      "types": "./dist/ecs.d.ts",
      "default": "./dist/ecs.js"
    },
    "./vi": {
      "types": "./dist/vi.d.ts",
      "default": "./dist/vi.js"
    },
    "./oss-direct-upload": {
      "types": "./dist/oss-direct-upload/index.d.ts",
      "default": "./dist/oss-direct-upload/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node dist/test.js",
    "login": "npm login --registry=https://registry.npmjs.org/",
    "pub": "npm run build && npm publish --access public --registry=https://registry.npmjs.org/ && node sync-npmmirror.js "
  },
  "author": "DC",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/node": "^20.8.3",
    "dotenv": "^16.4.5",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@alicloud/ecs20140526": "7.0.17",
    "@alicloud/imageseg20191230": "^4.0.1",
    "@alicloud/openapi-client": "^0.4.15",
    "ali-oss": "^6.20.0",
    "axios": "^1.6.8"
  }
}
